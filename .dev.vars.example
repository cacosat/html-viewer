# Copia este archivo a .dev.vars (no se commitea) para desarrollo local.
# En producción se configuran con: wrangler secret put AUTH_TOKEN  (y SESSION_SECRET)

# Token único de acceso a la plataforma.
AUTH_TOKEN="cambia-esto-por-un-token-secreto"

# Secreto para firmar la cookie de sesión (HMAC). Usa algo aleatorio y largo.
SESSION_SECRET="cambia-esto-por-un-secreto-aleatorio-largo"
